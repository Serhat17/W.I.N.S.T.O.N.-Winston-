# ============================================
# W.I.N.S.T.O.N. Environment Variables
# ============================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# All keys are OPTIONAL. Ollama works without any API keys.
# ============================================

# ── Local LLM (Ollama) ───────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Cloud LLM Providers (all optional) ───────
# Set any of these to enable that provider.
# Winston auto-falls back between providers if one fails.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=

# ── Email (IMAP/SMTP) ────────────────────────
WINSTON_SMTP_SERVER=smtp.gmail.com
WINSTON_SMTP_PORT=587
WINSTON_IMAP_SERVER=imap.gmail.com
WINSTON_EMAIL=your-email@gmail.com
WINSTON_EMAIL_PASSWORD=your-app-password

# ── Web Server / Web UI ──────────────────────
# PIN for the web UI login screen (leave empty to auto-generate)
WINSTON_PIN=

# ── Messaging Channels ───────────────────────
# Setting a token auto-enables the channel
WINSTON_TELEGRAM_TOKEN=
WINSTON_DISCORD_TOKEN=

# WhatsApp (via WAHA self-hosted Docker container)
# Start WAHA: docker run -p 3000:3000 devlikeapro/waha
WINSTON_WAHA_URL=http://localhost:3000

# ── Image Generation ─────────────────────────
# DALL-E 3 uses OPENAI_API_KEY above
# Stability AI (optional)
STABILITY_API_KEY=
# Pollinations (free, no key needed) is used as fallback

# ── Travel / Flights (Amadeus API) ───────────
# Free tier: ~2000 calls/month
# Sign up at https://developers.amadeus.com
WINSTON_AMADEUS_KEY=
WINSTON_AMADEUS_SECRET=

# ── Google Calendar (OAuth2) ─────────────────
# Download credentials JSON from Google Cloud Console
WINSTON_GOOGLE_CALENDAR_CREDS=

# ── Text-to-Speech (ElevenLabs) ──────────────
# Optional premium cloud TTS (falls back to Piper or macOS `say`)
WINSTON_ELEVENLABS_KEY=
WINSTON_ELEVENLABS_VOICE=

# ── Webhook Security ─────────────────────────
# Secret for external webhook triggers
WINSTON_WEBHOOK_SECRET=
